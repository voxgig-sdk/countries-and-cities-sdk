# Entity: country

main: kit: entity: country: {

  alias: field: {}

  fields: [
    {
      name: "city"
      req: false
      type: "`$ARRAY`"
    }
    {
      name: "code"
      req: false
      type: "`$STRING`"
    }
    {
      name: "country"
      op: {
        list: {
          req: false
          type: "`$STRING`"
        }
      }
      req: true
      type: "`$STRING`"
    }
    {
      name: "data"
      req: false
      type: "`$OBJECT`"
    }
    {
      name: "error"
      req: false
