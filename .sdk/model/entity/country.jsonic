          parts: [
            "countries"
            "flag"
            "images"
          ]
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
        {
          method: "POST"
          orig: "/countries/iso"
          parts: [
            "countries"
            "iso"
          ]
          select: {
            "$action": "iso"
          }
