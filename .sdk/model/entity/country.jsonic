        }
        {
          method: "POST"
          orig: "/countries/states"
          parts: [
            "countries"
            "states"
          ]
          select: {
            "$action": "state"
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
    list: {
      name: "list"
      points: [
        {
          method: "GET"
