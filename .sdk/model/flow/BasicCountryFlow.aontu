# BasicCountryFlow

main: kit: flow: BasicCountryFlow:
{
  entity: "country",
  kind: "basic",
  name: "BasicCountryFlow",
  step: [
    {
      input: {
        ref: "country_ref01"
      }

      op: "create"
    }

    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "country_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicCountryFlow"
}