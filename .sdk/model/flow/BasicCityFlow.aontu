# BasicCityFlow

main: kit: flow: BasicCityFlow:
{
  entity: "city",
  kind: "basic",
  name: "BasicCityFlow",
  step: [
    {
      input: {
        ref: "city_ref01"
      }

      op: "create"
    }

    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "city_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicCityFlow"
}