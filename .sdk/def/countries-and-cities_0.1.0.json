    "/countries/population/cities/filter": {
      "post": {
        "summary": "Filter cities by population",
        "description": "Filter cities based on population criteria",
        "operationId": "filterCitiesByPopulation",
        "tags": [
          "Cities"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "limit": {
                    "type": "integer",
                    "example": 10
                  },
                  "order": {
                    "type": "string",
                    "enum": [
                      "asc",
                      "dsc"
                    ],
                    "example": "dsc"
                  },
                  "orderBy": {
                    "type": "string",
                    "example": "population"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
