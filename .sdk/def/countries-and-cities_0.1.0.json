  "components": {
    "schemas": {
      "Country": {
        "type": "object",
        "properties": {
          "country": {
            "type": "string",
            "description": "Country name"
          },
          "cities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of cities in the country"
          }
        }
      },
      "CountryPopulation": {
        "type": "object",
        "properties": {
          "country": {
            "type": "string",
            "description": "Country name"
          },
          "code": {
            "type": "string",
            "description": "Country code"
          },
          "iso3": {
            "type": "string",
            "description": "ISO 3166-1 alpha-3 code"
          },
          "populationCounts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "year": {
                  "type": "integer"
                },
                "value": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "CountryFlag": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Country name"
          },
          "flag": {
            "type": "string",
            "format": "uri",
            "description": "URL to the country flag image"
          },
          "iso2": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 code"
          },
          "iso3": {
            "type": "string",
            "description": "ISO 3166-1 alpha-3 code"
          }
        }
      },
      "CountryPosition": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Country name"
          },
          "iso2": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 code"
          },
          "long": {
            "type": "number",
            "format": "double",
            "description": "Longitude"
          },
          "lat": {
            "type": "number",
            "format": "double",
            "description": "Latitude"
          }
        }
      },
      "CityPopulation": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "description": "City name"
          },
          "country": {
            "type": "string",
            "description": "Country name"
          },
          "populationCounts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "year": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                },
                "sex": {
                  "type": "string"
                },
                "reliabilty": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
