{
  "openapi": "3.0.3",
  "info": {
    "title": "Countries & Cities API",
    "description": "Provides population and geographical data for countries and cities. Use it to get detailed information on populations, locations, flags, currencies, capitals, and more. Access endpoints to retrieve single city data, country codes, and other related details. No API key required.",
    "version": "1.0.0",
    "contact": {
      "url": "https://documenter.getpostman.com/view/1134062/T1LJjU52"
    }
  },
  "servers": [
    {
      "url": "https://countriesnow.space/api/v0.1",
      "description": "Production server"
    }
  ],
